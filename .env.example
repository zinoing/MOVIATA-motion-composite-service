# ── CORS ─────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,https://moviata.com

# ── SAM2 Model ────────────────────────────────────────────────────────────────
SAM2_CHECKPOINT_DIR=./checkpoints/sam2
# URL to download sam2.1_hiera_small.pt from on first boot (leave empty to skip)
R2_CHECKPOINT_URL=

# ── Upload limits ─────────────────────────────────────────────────────────────
MAX_UPLOAD_SIZE_MB=500
MAX_VIDEO_DURATION_SEC=60

# ── Redis / Celery (only needed for /upload legacy endpoint) ──────────────────
# Use redis:// for plain or rediss:// for TLS (Upstash requires rediss://)
REDIS_URL=redis://localhost:6379/0

# ── Cloudflare R2 (only needed for /presigned-upload and /extract-frames) ─────
# These endpoints are not called in the current browser-capture flow.
CLOUDFLARE_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_TEMP=moviata-temp
